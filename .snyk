# Snyk Code policy.
#
# Excludes confirmed Class A path-traversal false positives: paths an operator
# (or CI) passes on the command line of a local dev tool, flowing into open()
# or os.walk. These tools have no privilege boundary — the caller already has
# filesystem access and opening the supplied path is the tool's job — so there
# is no traversal risk to fix.
#
# These are excluded rather than guarded in code because the containment base
# is itself the caller-supplied path, so there is no trusted base for Snyk to
# recognise a sanitiser against; a whole-file exclude is the only committed
# mechanism Snyk Code honours for its findings.
#
# Genuine trust boundaries are fixed in code, not excluded (SSRF host allowlist,
# zip-slip member check). tool-catalog-drift.py is the one exception below: its
# SSRF is fixed and tested, but Snyk does not credit the sanitiser, so the file
# is excluded too.
#
# Full threat model: SECURITY.md.
version: v1.25.1
ignore: {}
patch: {}
# Snyk's `.snyk` exclude entries are plain scalar path/glob strings — NOT
# mappings with a nested `reason:`. An invalid `.snyk` is silently dropped and
# the scan continues WITHOUT the exclusions, so each rationale lives in a
# comment directly above its entry rather than inline. See SECURITY.md for the
# full per-file threat model.
#   https://docs.snyk.io/scan-with-snyk/import-project-repository/exclude-directories-and-files-from-project-import
exclude:
  global:
    # Meta-skill entry points — operator-supplied skill/system/corpus path.
    #
    # audit_skill_system.py — Class A: operator-supplied CLI path (system/skill
    #   root) walked and opened; no privilege boundary.
    - skill-system-foundry/scripts/audit_skill_system.py
    # validate_skill.py — Class A: operator-supplied CLI skill path walked and
    #   opened; no privilege boundary.
    - skill-system-foundry/scripts/validate_skill.py
    # evaluate_descriptions.py — Class A: operator-supplied corpus/skill-set
    #   paths opened; no privilege boundary.
    - skill-system-foundry/scripts/evaluate_descriptions.py
    # bundle.py — Class A: operator-supplied skill/system-root/output paths; no
    #   privilege boundary.
    - skill-system-foundry/scripts/bundle.py
    # scaffold.py — Class A: operator-supplied --root scaffold target
    #   opened/written; no privilege boundary.
    - skill-system-foundry/scripts/scaffold.py
    # reference_conformance_report.py — Class A: operator-supplied skill path
    #   opened; no privilege boundary.
    - skill-system-foundry/scripts/reference_conformance_report.py
    # stats.py — Class A: operator-supplied skill path walked and opened; no
    #   privilege boundary.
    - skill-system-foundry/scripts/stats.py
    # yaml_conformance_report.py — Class A: operator-supplied corpus-root path
    #   opened; no privilege boundary.
    - skill-system-foundry/scripts/yaml_conformance_report.py
    # CI helper scripts — operator/CI-supplied path arguments.
    #
    # refresh-yaml-corpus-digests.py — Class A: CI-supplied corpus-root path
    #   walked and hashed; no privilege boundary.
    - .github/scripts/refresh-yaml-corpus-digests.py
    # smoke-rewrite-frontmatter.py — Class A: CI-supplied SKILL.md path
    #   read/written; no privilege boundary.
    - .github/scripts/smoke-rewrite-frontmatter.py
    # check-per-file-coverage.py — Class A: CI-supplied coverage.json/.coveragerc
    #   paths read; no privilege boundary.
    - .github/scripts/check-per-file-coverage.py
    # verify-action-pins.py — Class A: CI-supplied workflows-dir path walked and
    #   read; no privilege boundary.
    - .github/scripts/verify-action-pins.py
    # tool-catalog-drift.py — mixed file: SSRF is hardened in code (hardcoded
    #   host allowlist enforced pre-request and on every redirect target before
    #   it is followed, plus landing-URL re-validation) and covered by tests,
    #   but Snyk Code does not credit the sanitizer; the remaining python/PT are
    #   Class A operator-supplied --catalog-path reads/writes with no privilege
    #   boundary. Regression guarded by .github/tests/test_tool_catalog_drift.py.
    - .github/scripts/tool-catalog-drift.py
